{
	"name": "@nextcloud/vite-config",
	"version": "3.0.0-dev.0",
	"description": "Shared Vite configuration for Nextcloud apps and libraries",
	"homepage": "https://github.com/nextcloud-libraries/nextcloud-vite-config",
	"bugs": {
		"url": "https://github.com/nextcloud-libraries/nextcloud-vite-config/issues"
	},
	"license": "AGPL-3.0-or-later",
	"author": "Nextcloud GmbH and Nextcloud contributors",
	"contributors": [
		"Andy Scherzinger <info@andy-scherzinger.de>",
		"Ferdinand Thiessen <opensource@fthiessen.de>",
		"Grigorii K. Shartsev <me@shgk.me>",
		"John Molakvoæ <skjnldsv@protonmail.com>",
		"Julius Knorr <jus@bitgrid.net>",
		"Raimund Schlüßler <raimund.schluessler+github@mailbox.org>",
		"Richard Steinmetz <richard@steinmetz.cloud>"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist/",
		"LICENSES"
	],
	"scripts": {
		"build": "tsc",
		"build:doc": "typedoc --out dist/doc lib/index.ts && touch dist/doc/.nojekyll",
		"dev": "tsc --watch",
		"lint": "eslint",
		"lint:fix": "eslint --fix",
		"prerelease:format-changelog": "node build/format-changelog.mjs",
		"pretest": "npm run build && npm pack && mv nextcloud-vite-config-*.tgz nextcloud-vite-config.tgz",
		"test": "cd tests && npm run test",
		"test:watch": "cd tests && npm run test:watch",
		"ts:check": "tsc --noEmit"
	},
	"dependencies": {
		"browserslist-to-esbuild": "^2.1.1",
		"magic-string": "^0.30.21",
		"rolldown-plugin-dts": "^0.23.2",
		"rollup-plugin-corejs": "^1.0.2",
		"rollup-plugin-node-externals": "^8.1.2",
		"spdx-expression-parse": "^4.0.0",
		"vite-plugin-css-injected-by-js": "^4.0.1",
		"vite-plugin-node-polyfills": "^0.26.0"
	},
	"devDependencies": {
		"@nextcloud/eslint-config": "^9.0.0-rc.9",
		"@types/node": "^24.12.2",
		"@types/spdx-expression-parse": "^4.0.0",
		"@vitest/coverage-v8": "^4.1.4",
		"eslint": "^10.2.0",
		"typedoc": "^0.28.18",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "^4.1.3"
	},
	"peerDependencies": {
		"@vitejs/plugin-vue": ">=2.0",
		"browserslist": ">=4.20",
		"sass": ">=1.60",
		"vite": ">=8.0"
	},
	"engines": {
		"node": "^22.12 || ^24"
	},
	"devEngines": {
		"packageManager": [
			{
				"name": "npm",
				"version": "^11.3.0",
				"onFail": "error"
			}
		],
		"runtime": {
			"name": "node",
			"version": "^24",
			"onFail": "error"
		}
	}
}
